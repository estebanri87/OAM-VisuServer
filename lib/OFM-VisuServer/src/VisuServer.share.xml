            <!-- ====================================================
                 Parameter Types (VIS-specific)
                 ==================================================== -->
            <ParameterTypes>

              <!-- 20-byte name field (rooms, floors, widgets, device) -->
              <ParameterType Id="%AID%_PT-VISText20" Name="VISText20">
                <TypeText SizeInBit="160" />
