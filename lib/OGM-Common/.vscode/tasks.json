{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "OpenKNX-Producer Documentation (for Common Only)",
            "type": "shell",
            "command": "~/bin/OpenKNXproducer.exe",
            "args": [
                "baggages",
                "--DocFileName",
                "doc/Applikationsbeschreibung-Common.md",
                "--BaggagesDir",
                "src/Baggages/Help_de",
                "--Prefix",
                "BASE"
            ],
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "OpenKNX-Producer Documentation (for All Modules)",
            "type": "shell",
            "command": "~/bin/OpenKNXproducer.exe",
            "args": [
                "baggages",
                "--DocFileName",
                "doc/Applikationsbeschreibung-ContextHelpOnly.md",
                "--BaggagesDir",
                "src/Baggages/Help_de",
                "--Prefix",
                "BASE"
            ],
            "problemMatcher": [],
            "group": "test"
        },
        {
            "label": "OpenKNX-Producer Documentation",
            "dependsOn": [
                "OpenKNX-Producer Documentation (for Common Only)", 
                "OpenKNX-Producer Documentation (for All Modules)"
            ],
            "dependsOrder": "sequence",
            "group": "test"
        }        
    ]
}